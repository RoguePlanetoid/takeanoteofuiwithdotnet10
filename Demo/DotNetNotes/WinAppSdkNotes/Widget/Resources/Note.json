{
  "$schema": "https://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.6",
  "header": null,
  "backgroundImage": {
    "url": "${Image}",
    "fillMode": "Cover",
    "horizontalAlignment": "Center",
    "verticalAlignment": "Center"
  },
  "body": [
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "${Selected.Title}",
              "weight": "Bolder",
              "size": "large",
              "wrap": true
            },
            {
              "type": "TextBlock",
              "text": "${Selected.Content}",
              "size": "large",
              "wrap": true
            }
          ]
        }
      ]
    }
  ]
}